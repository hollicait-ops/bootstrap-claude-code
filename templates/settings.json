{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "theme": "dark",
  "autoMemory": true,
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git fetch*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(wc*)",
      "Bash(which*)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npm install*)",
      "Bash(yarn*)",
      "Bash(pnpm*)",
      "Bash(make*)",
      "Bash(cargo*)",
      "Bash(go build*)",
      "Bash(go test*)",
      "Bash(go fmt*)",
      "Bash(python* -m pytest*)",
      "Bash(python* -m unittest*)",
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(uv*)",
      "Bash(poetry*)",
      "Bash(pipenv*)",
      "Bash(gem install*)",
      "Bash(bundle*)",
      "Bash(mix*)",
      "Bash(hex*)",
      "Bash(gh issue*)",
      "Bash(gh pr*)",
      "Bash(gh repo*)",
      "Bash(gh run*)",
      "Bash(gh release*)",
      "Bash(docker build*)",
      "Bash(docker run*)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(docker logs*)",
      "Bash(docker-compose up*)",
      "Bash(docker-compose down*)",
      "Bash(docker-compose build*)",
      "Bash(podman build*)",
      "Bash(podman run*)",
      "Bash(podman ps*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",
      "Bash(helm list*)",
      "Bash(helm status*)",
      "Bash(terraform init*)",
      "Bash(terraform plan*)",
      "Bash(terraform validate*)",
      "Bash(tofu init*)",
      "Bash(tofu plan*)",
      "Bash(tofu validate*)",
      "Bash(mkdir -p*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(touch*)",
      "Bash(echo*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf /home*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(echo* | bash*)",
      "Bash(echo* | sh*)",
      "Bash(echo* | zsh*)",
      "Bash(echo* | dash*)",
      "Bash(chmod 777*)",
      "Bash(sudo rm*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Bash(dd if=/dev/*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git push --force-with-lease*)",
      "Bash(npm publish*)",
      "Bash(yarn publish*)",
      "Bash(pnpm publish*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(rm -rf*)",
      "Bash(docker rm*)",
      "Bash(docker rmi*)",
      "Bash(docker-compose down -v*)",
      "Bash(podman rm*)",
      "Bash(psql*)",
      "Bash(mysql*)",
      "Bash(mongosh*)",
      "Bash(redis-cli*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl delete*)",
      "Bash(helm install*)",
      "Bash(helm upgrade*)",
      "Bash(helm uninstall*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(tofu apply*)",
      "Bash(tofu destroy*)"
    ]
  },
  "hooks": {}
}
