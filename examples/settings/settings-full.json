{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  // Model to use by default. Override per-session with /model
  "model": "claude-sonnet-4-6",

  // Terminal theme
  "theme": "dark",

  // Automatically save important context to ~/.claude/memory/
  "autoMemory": true,

  // Inject git repo info into session context
  "includeGitInstructions": true,

  // Default mode: "chat" (normal) or "plan" (require plan approval before acting)
  // "defaultMode": "plan",

  "permissions": {
    // Commands Claude can run without asking.
    // Glob patterns: * = any chars except /, ** = any chars including /
    "allow": [
      // Git read operations
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git stash list)",

      // Git write operations (commonly safe)
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",

      // File system read
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(find*)",
      "Bash(grep*)",

      // Tool discovery
      "Bash(which*)",
      "Bash(* --version)",
      "Bash(* --help)",

      // Build tools
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npm install*)",
      "Bash(yarn*)",
      "Bash(pnpm*)",
      "Bash(make*)",
      "Bash(cargo*)",
      "Bash(go build*)",
      "Bash(go test*)",
      "Bash(go fmt*)",
      "Bash(python* -m pytest*)",
      "Bash(python* -m unittest*)",

      // File manipulation (non-destructive)
      "Bash(mkdir -p*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(touch*)",

      // Python package managers
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(uv*)",
      "Bash(poetry*)",
      "Bash(pipenv*)",

      // Ruby
      "Bash(gem install*)",
      "Bash(bundle*)",

      // Elixir
      "Bash(mix*)",
      "Bash(hex*)",

      // GitHub CLI
      "Bash(gh issue*)",
      "Bash(gh pr*)",
      "Bash(gh repo*)",
      "Bash(gh run*)",
      "Bash(gh release*)",

      // Docker (read-only / build)
      "Bash(docker build*)",
      "Bash(docker run*)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(docker logs*)",
      "Bash(docker-compose up*)",
      "Bash(docker-compose down*)",
      "Bash(docker-compose build*)",

      // Podman
      "Bash(podman build*)",
      "Bash(podman run*)",
      "Bash(podman ps*)",

      // Kubernetes (read-only)
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",

      // Helm (read-only)
      "Bash(helm list*)",
      "Bash(helm status*)",

      // Terraform / OpenTofu (read-only)
      "Bash(terraform init*)",
      "Bash(terraform plan*)",
      "Bash(terraform validate*)",
      "Bash(tofu init*)",
      "Bash(tofu plan*)",
      "Bash(tofu validate*)",

      // Edit within specific directories (project-level override)
      // "Edit(./src/**)",
      // "Edit(./tests/**)"

      // Echo is safe for routine output; pipe-to-shell patterns are blocked in deny below.
      "Bash(echo*)"
    ],

    // Commands Claude is never allowed to run, even if the user asks.
    // deny takes precedence over allow.
    "deny": [
      // Catastrophically destructive shell commands
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf /home*)",

      // Force push and hard reset (destructive git)
      // Note: --force-with-lease is moved to ask — it is safer than bare --force
      // (only pushes if no one else has pushed since your last fetch).
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",

      // Echo piped to a shell interpreter can execute arbitrary code
      "Bash(echo* | bash*)",
      "Bash(echo* | sh*)",

      // Privilege escalation
      "Bash(sudo rm*)",
      "Bash(chmod 777*)",

      // Raw disk writes
      "Bash(dd if=/dev/*)",

      // Secret files — never read or edit
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ],

    // Commands Claude will ask permission before running.
    "ask": [
      // Network pushes
      "Bash(git push*)",
      // --force-with-lease is safer than bare --force: it refuses to push if the
      // remote has commits you haven't fetched. Requiring confirmation is enough.
      "Bash(git push --force-with-lease*)",
      "Bash(npm publish*)",
      "Bash(yarn publish*)",
      "Bash(pnpm publish*)",

      // Network requests
      "Bash(curl*)",
      "Bash(wget*)",

      // Recursive deletes (not covered by deny)
      "Bash(rm -rf*)",

      // Container cleanup
      "Bash(docker rm*)",
      "Bash(docker rmi*)",
      "Bash(docker-compose down -v*)",
      "Bash(podman rm*)",

      // Databases
      "Bash(psql*)",
      "Bash(mysql*)",
      "Bash(mongosh*)",
      "Bash(redis-cli*)",

      // Kubernetes writes
      "Bash(kubectl apply*)",
      "Bash(kubectl delete*)",

      // Helm writes
      "Bash(helm install*)",
      "Bash(helm upgrade*)",
      "Bash(helm uninstall*)",

      // Infrastructure changes
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(tofu apply*)",
      "Bash(tofu destroy*)"
    ]
  },

  // Hooks are registered here by the installer after hook scripts are copied.
  // See docs/04-hooks.md for the format.
  //
  // Unix/macOS — the installer writes this automatically:
  //   "hooks": {
  //     "PreToolUse":   [{"matcher":"*","hooks":[{"type":"command","command":"/home/you/.claude/hooks/pre-tool-use.sh"}]}],
  //     "PostToolUse":  [{"matcher":"*","hooks":[{"type":"command","command":"/home/you/.claude/hooks/post-tool-use.sh"}]}],
  //     "Stop":         [{"hooks":[{"type":"command","command":"/home/you/.claude/hooks/stop.sh"}]}],
  //     "SessionStart": [{"hooks":[{"type":"command","command":"/home/you/.claude/hooks/session-start.sh"}]}]
  //   }
  //
  // Windows — Claude Code cannot execute .ps1 files directly. Wrap every hook
  // command in a pwsh invocation. Replace C:\Users\you with your %USERPROFILE%.
  // Use powershell.exe if PowerShell 7 (pwsh) is not installed.
  // If your username contains spaces, quote the file path (see last note below).
  //
  //   "hooks": {
  //     "PreToolUse":   [{"matcher":"*","hooks":[{"type":"command","command":"pwsh -NonInteractive -ExecutionPolicy Bypass -File \"C:\\Users\\you\\.claude\\hooks\\pre-tool-use.ps1\""}]}],
  //     "PostToolUse":  [{"matcher":"*","hooks":[{"type":"command","command":"pwsh -NonInteractive -ExecutionPolicy Bypass -File \"C:\\Users\\you\\.claude\\hooks\\post-tool-use.ps1\""}]}],
  //     "Stop":         [{"hooks":[{"type":"command","command":"pwsh -NonInteractive -ExecutionPolicy Bypass -File \"C:\\Users\\you\\.claude\\hooks\\stop.ps1\""}]}],
  //     "SessionStart": [{"hooks":[{"type":"command","command":"pwsh -NonInteractive -ExecutionPolicy Bypass -File \"C:\\Users\\you\\.claude\\hooks\\session-start.ps1\""}]}]
  //   }
  //
  // Spaces in path are handled safely by the quotes above — no extra changes needed.
  // See also: examples/settings/settings-full-windows.json
  "hooks": {},

  // MCP server configuration. See docs/05-mcp-servers.md.
  // "mcpServers": {
  //   "filesystem": {
  //     "command": "npx",
  //     "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/dir"]
  //   }
  // }
}
